# JerryQuant secrets — copy to .env and fill in. NEVER commit .env.

# --- Robinhood MCP (live trading; leave blank until you are ready) ---
# Robinhood's agentic trading MCP endpoint is:
#   https://agent.robinhood.com/mcp/trading
# Leave these BLANK until backtesting and paper trading are validated.
# Live trading additionally requires execution.live_trading_enabled: true
# in config.yaml AND mode LIVE_APPROVED AND per-trade manual approval.
ROBINHOOD_MCP_URL=
ROBINHOOD_MCP_API_KEY=

# --- Email reports (SMTP). If unset, reports print to terminal + file. ---
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=your gmail
# address, SMTP_PASSWORD=a 16-character App Password generated at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# Your normal Gmail password will NOT work and should never go here.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_FROM=
REPORT_EMAIL_TO=stephenjerryguy@gmail.com

# --- Optional data sources (all unused at launch; stubs only) ---
POLYMARKET_API_URL=
KALSHI_API_KEY=
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=
