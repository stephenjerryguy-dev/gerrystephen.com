{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy",
      "permanent": true
    },
    {
      "source": "/studio",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/studio",
      "permanent": true
    },
    {
      "source": "/sealfolio",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/sealfolio",
      "permanent": true
    },
    {
      "source": "/community",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/community",
      "permanent": true
    },
    {
      "source": "/ecosystem",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/ecosystem",
      "permanent": true
    },
    {
      "source": "/memes",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/memes",
      "permanent": true
    },
    {
      "source": "/sappy",
      "has": [{ "type": "host", "value": "gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy",
      "permanent": true
    },
    {
      "source": "/sappy/:path*",
      "has": [{ "type": "host", "value": "gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/:path*",
      "permanent": true
    },
    {
      "source": "/sappy",
      "has": [{ "type": "host", "value": "www.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy",
      "permanent": true
    },
    {
      "source": "/sappy/:path*",
      "has": [{ "type": "host", "value": "www.gerrystephen.com" }],
      "destination": "https://sappy.gerrystephen.com/sappy/:path*",
      "permanent": true
    },
    {
      "source": "/monerge",
      "destination": "https://biome.gerrystephen.com/monerge",
      "permanent": true
    },
    {
      "source": "/monerge/:path*",
      "destination": "https://biome.gerrystephen.com/monerge",
      "permanent": true
    },
    {
      "source": "/moncade",
      "destination": "https://biome.gerrystephen.com/moncade",
      "permanent": true
    },
    {
      "source": "/moncade/:path*",
      "destination": "https://biome.gerrystephen.com/moncade",
      "permanent": true
    },
    {
      "source": "/moncade-game",
      "destination": "https://biome.gerrystephen.com/moncade",
      "permanent": true
    },
    {
      "source": "/moncade-game/:path*",
      "destination": "https://biome.gerrystephen.com/moncade",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/sappy-profile",
      "destination": "/api/sappy-profile"
    },
    {
      "source": "/api/:path*",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "/assets/:path*"
    },
    {
      "source": "/src/:path*",
      "has": [{ "type": "host", "value": "sappy.gerrystephen.com" }],
      "destination": "/src/:path*"
    },
    { "source": "/fresh", "destination": "/" },
    { "source": "/reset-app", "destination": "/" },
    { "source": "/dynamic-api/:path*", "destination": "https://app.dynamicauth.com/api/v0/:path*" },
    { "source": "/monerge", "destination": "/monerge.html" },
    { "source": "/monerge/:path*", "destination": "/monerge.html" },
    { "source": "/moncade", "destination": "/moncade.html" },
    { "source": "/moncade/:path*", "destination": "/moncade.html" },
    { "source": "/moncade-game", "destination": "/moncade-game.html" },
    { "source": "/moncade-game/:path*", "destination": "/moncade-game.html" },
    { "source": "/sappy", "destination": "/sappy.html" },
    { "source": "/sappy/studio", "destination": "/sappy/studio.html" },
    { "source": "/sappy/studio/", "destination": "/sappy/studio.html" },
    { "source": "/:path*", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(fresh|reset-app)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Clear-Site-Data", "value": "\"cache\", \"storage\", \"executionContexts\"" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(index.html|sappy.html|monerge.html|moncade.html|moncade-game.html|service-worker.js|manifest.webmanifest|monerge.webmanifest|sappy|monerge|moncade|moncade-game)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
