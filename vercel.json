{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/fresh", "destination": "/" },
    { "source": "/reset-app", "destination": "/" },
    { "source": "/dynamic-api/:path*", "destination": "https://app.dynamicauth.com/api/v0/:path*" },
    { "source": "/monerge", "destination": "/monerge.html" },
    { "source": "/monerge/:path*", "destination": "/monerge.html" },
    { "source": "/moncade", "destination": "/moncade.html" },
    { "source": "/moncade/:path*", "destination": "/moncade.html" },
    { "source": "/moncade-game", "destination": "/moncade-game.html" },
    { "source": "/moncade-game/:path*", "destination": "/moncade-game.html" },
    { "source": "/sappy", "destination": "/sappy.html" },
    { "source": "/:path*", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(fresh|reset-app)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Clear-Site-Data", "value": "\"cache\", \"storage\", \"executionContexts\"" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(index.html|sappy.html|monerge.html|moncade.html|moncade-game.html|service-worker.js|manifest.webmanifest|monerge.webmanifest|sappy|monerge|moncade|moncade-game)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
